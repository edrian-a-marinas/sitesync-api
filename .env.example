# Database
DATABASE_URL=postgresql+asyncpg://<username>:<password>@postgres/sitesync_dev
TEST_DATABASE_URL=postgresql+asyncpg://<username>:<password>@localhost/sitesync_test

# Application
DEBUG= # Bool, eg True during dev
RATELIMIT_ENABLED=  # Bool, eg False during dev
SECRET_KEY=     # required - generate random string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
HF_HUB_OFFLINE= # embedding

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

MONGO_URL=mongodb://localhost:27017/sitesync

# External APIs
GROQ_API_KEY=    # required to boot (any string works) — real key needed only for AI query feature

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# AWS Services — optional for local dev, only needed if testing S3 uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_ACCOUNT_ID=
AWS_S3_BUCKET=

## Deployment and CICD
# Required GitHub Secrets: EC2_HOST, EC2_USER, EC2_SSH_KEY